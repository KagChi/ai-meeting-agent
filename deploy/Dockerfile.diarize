# syntax=docker/dockerfile:1.7
# Diarization Service — Ubuntu 24.04 + CUDA 12.6/cuDNN for ONNX Runtime CUDA EP.
# ort 2.0.0-rc.12 defaults to cu12 binaries (libcudart.so.12); CUDA 13 images break GPU.

FROM nvidia/cuda:12.6.3-cudnn-devel-ubuntu24.04 AS builder
ENV DEBIAN_FRONTEND=noninteractive
# Ensure ort-sys downloads the cu12 CUDA EP package when building with cuda feature.
ENV ORT_CUDA_VERSION=12

RUN apt-get update && apt-get install -y --no-install-recommends \
        ca-certificates curl pkg-config g++ git make perl \
        libssl-dev libopenblas-dev \
    && rm -rf /var/lib/apt/lists/*

RUN curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs \
    | sh -s -- -y --default-toolchain 1.94.0 --profile minimal
ENV PATH="/root/.cargo/bin:${PATH}"

WORKDIR /app
COPY Cargo.toml Cargo.lock ./
COPY crates/ ./crates/

# BuildKit caches keep cargo registry + target between builds without cargo-chef overhead.
# Also extract ONNX Runtime shared libraries that ort-sys downloads for CUDA support.
RUN --mount=type=cache,target=/root/.cargo/registry \
    --mount=type=cache,target=/root/.cargo/git \
    --mount=type=cache,target=/app/target \
    cargo build --release --package meeting-agent-diarize-service \
    && cp /app/target/release/meeting-agent-diarize-service /app/diarize-service \
    && mkdir -p /onnxruntime-libs \
    && echo "Searching for ONNX Runtime libraries..." \
    && find /app/target/release/build -name "libonnxruntime*.so*" -exec cp -v {} /onnxruntime-libs/ \; \
    && ls -la /onnxruntime-libs/ \
    && if [ -z "$(ls -A /onnxruntime-libs/)" ]; then \
         echo "WARNING: No ONNX Runtime libraries found - CUDA support may not work"; \
       else \
         echo "Found ONNX Runtime libraries for CUDA support"; \
       fi

FROM nvidia/cuda:12.6.3-cudnn-runtime-ubuntu24.04
ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y --no-install-recommends \
        ca-certificates curl libopenblas0 \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app
COPY --from=builder /app/diarize-service /app/diarize-service

# Copy ONNX Runtime libraries needed for CUDA Execution Provider
# Copy entire directory first, then move libs with shell to handle empty case
COPY --from=builder /onnxruntime-libs /onnxruntime-libs
RUN if [ -n "$(ls -A /onnxruntime-libs 2>/dev/null)" ]; then \
      echo "Copying ONNX Runtime libraries to /usr/local/lib/"; \
      cp -v /onnxruntime-libs/* /usr/local/lib/ && ldconfig; \
    else \
      echo "WARNING: No ONNX Runtime libraries found - CUDA support will not work"; \
    fi && rm -rf /onnxruntime-libs

# hf-hub / speakrs cache (override with HF_HOME in compose)
RUN mkdir -p /tmp/diarize-service /app/.cache/huggingface

# HOME=/app so any leftover Cache::default() paths stay on the volume too.
ENV RUST_LOG=info \
    DIARIZE_HOST=0.0.0.0 \
    DIARIZE_PORT=8001 \
    DIARIZE_EXECUTION_MODE=cuda-fast \
    HOME=/app \
    HF_HOME=/app/.cache/huggingface \
    TEMP=/tmp/diarize-service \
    NVIDIA_VISIBLE_DEVICES=all \
    NVIDIA_DRIVER_CAPABILITIES=compute,utility

EXPOSE 8001

HEALTHCHECK --interval=30s --timeout=10s --start-period=60s --retries=3 \
    CMD curl -f http://localhost:8001/health || exit 1

CMD ["/app/diarize-service"]
