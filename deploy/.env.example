# ============================================================================
# AI Meeting Agent — deployment env (self-hosted, DGX Spark)
# Copy to deploy/.env and fill in. Used by deploy/docker-compose.yml
# (and optionally deploy/docker-compose.bots.yml for Vexa join/record).
# ============================================================================

# Compose project name (must match DOCKER_NETWORK for Vexa bot spawn when using bots.yml)
COMPOSE_PROJECT_NAME=meeting-agent

# ---- Host port map (change if they collide with the Vexa stack) ----
WHISPERX_HOST_PORT=8010
LLM_HOST_PORT=11434
SERVER_HOST_PORT=8080

# ---- ASR (WhisperX / faster-whisper, OpenAI-compatible) ----
# Used by meeting-agent-server only (import pipeline). Not wired to Vexa.
# large-v3 covers EN + Mandarin + Indonesian incl. code-switching (see PRD §5).
WHISPERX_IMAGE=ghcr.io/speaches-ai/speaches:latest-cuda
ASR_MODEL=Systran/faster-whisper-large-v3
ASR_COMPUTE_TYPE=float16

# ---- Minutes / action-item LLM (OpenAI-compatible) ----
# Qwen2.5 is strong across EN/ZH/ID. Pull it once: see deploy/README.md.
LLM_IMAGE=ollama/ollama:latest
LLM_MODEL=qwen2.5:32b
LLM_KEEP_ALIVE=30m

# ---- Diarization (same DIARIZE_* keys as core Config) ----
DIARIZE_IMAGE=ghcr.io/bmw-ece-ntust/ai-meeting-agent/meeting-agent-diarize-service:latest
DIARIZE_ENABLED=false                # Set true to enable speaker diarization in meeting-agent-server
DIARIZE_SERVICE_URL=http://diarize-service:8001  # Remote service; leave empty for in-process
# GPU service image is CUDA 12.6 + cuDNN (ORT cu12). Prefer cuda-fast on DGX.
DIARIZE_EXECUTION_MODE=cuda-fast     # auto|cpu|cuda|cuda-fast|migraphx|coreml|coreml-fast
DIARIZE_MODEL_DIR=                   # Optional local models path (blank = HF download via HF_HOME)
# Voiceprint embeddings (CAM++_LM default; re-enroll if switching models)
DIARIZE_EMBEDDING_MODEL=wespeaker-voxceleb-CAM++_LM
DIARIZE_EMBEDDING_DIM=512
# Service uses HF_HOME=/app/.cache/huggingface (diarize-models volume). Wipe volume if partial cache.
DIARIZE_HOST_PORT=8001               # Host port published for diarize-service

# ---- meeting-agent-server ----
TRANSCRIPTION_API_KEY=not-needed-local
SUMMARY_API_KEY=not-needed-local

# ---- Meeting bot worker (services/meeting-bot; internal) ----
# Meetily calls agent POST /bots only; agent proxies to this URL.
MEETING_BOT_ENABLED=false
MEETING_BOT_URL=http://127.0.0.1:8091
MEETING_BOT_INTERNAL_KEY=

# ---- Orchestrator (optional: Vexa meeting-end → download → import) ----
ORCHESTRATOR_ENABLED=false
VEXA_API_BASE=http://127.0.0.1:18056
VEXA_API_KEY=
VEXA_WEBHOOK_SECRET=
MINIO_ENDPOINT=
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=vexa
MINIO_SECURE=false

# ---- Post-meeting automation (Phase 4) ----
# Where per-meeting action items are appended (lab daily-log / progress-plan issue).
DAILY_LOG_TARGET=
# Google Calendar service-account JSON path (mounted into orchestrator).
GOOGLE_CALENDAR_CREDENTIALS=/secrets/gcal.json
