# ============================================================================
# AI Meeting Agent — deployment env (self-hosted, DGX Spark)
# Copy to deploy/.env and fill in. Used by deploy/docker-compose.yml
# ============================================================================

COMPOSE_PROJECT_NAME=meeting-agent

# ---- Host port map ----
WHISPERX_HOST_PORT=8010
LLM_HOST_PORT=11434
SERVER_HOST_PORT=8080
# meeting-bot is internal; bind localhost only for debug
MEETING_BOT_HOST_PORT=127.0.0.1:8091

# ---- Images (override after ./deploy/docker-build.sh) ----
SERVER_IMAGE=ghcr.io/bmw-ece-ntust/ai-meeting-agent/meeting-agent-server:latest
DIARIZE_IMAGE=ghcr.io/bmw-ece-ntust/ai-meeting-agent/meeting-agent-diarize-service:latest
MEETING_BOT_IMAGE=ghcr.io/bmw-ece-ntust/ai-meeting-agent/meeting-bot:latest

# ---- ASR (WhisperX / faster-whisper, OpenAI-compatible) ----
WHISPERX_IMAGE=ghcr.io/speaches-ai/speaches:latest-cuda
ASR_MODEL=Systran/faster-whisper-large-v3
ASR_COMPUTE_TYPE=float16

# ---- Minutes / action-item LLM ----
LLM_IMAGE=ollama/ollama:latest
LLM_MODEL=qwen2.5:32b
LLM_KEEP_ALIVE=30m

# ---- Diarization ----
DIARIZE_ENABLED=false
DIARIZE_SERVICE_URL=http://diarize-service:8001
DIARIZE_EXECUTION_MODE=cuda-fast
DIARIZE_MODEL_DIR=
DIARIZE_EMBEDDING_MODEL=wespeaker-voxceleb-CAM++_LM
DIARIZE_EMBEDDING_DIM=512
DIARIZE_HOST_PORT=8001

# ---- meeting-agent-server ----
TRANSCRIPTION_API_KEY=not-needed-local
SUMMARY_API_KEY=not-needed-local
# Optional public API key for Meetily / clients
MEETING_AGENT_API_KEY=

# ---- Meeting bot worker (services/meeting-bot; internal) ----
# Meetily calls only agent POST /bots; agent proxies to MEETING_BOT_URL.
MEETING_BOT_ENABLED=true
MEETING_BOT_URL=http://meeting-bot:8091
MEETING_BOT_INTERNAL_KEY=
MEETING_BOT_HEADLESS=true
BOT_NAME=BMW-Lab-Bot
JOIN_TIMEOUT_MS=900000
MAX_CONCURRENT_BOTS=1

# ---- Optional: Vexa orchestrator path (legacy sibling stack) ----
ORCHESTRATOR_ENABLED=false
VEXA_API_BASE=http://127.0.0.1:18056
VEXA_API_KEY=
VEXA_WEBHOOK_SECRET=
MINIO_ENDPOINT=
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=vexa
MINIO_SECURE=false

# ---- Post-meeting automation (Phase 4 remainder) ----
DAILY_LOG_TARGET=
GOOGLE_CALENDAR_CREDENTIALS=/secrets/gcal.json
