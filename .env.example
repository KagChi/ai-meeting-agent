# Meeting Agent Environment Variables

# Server Configuration
MEETING_AGENT_PORT=8080
MEETING_AGENT_HOST=127.0.0.1
MEETING_AGENT_DATA_DIR=~/.meeting-agent
MEETING_AGENT_API_KEY=

# Transcription Configuration
# Choose one provider configuration below and uncomment it

# Option 1: OpenAI
TRANSCRIPTION_PROVIDER=openai
TRANSCRIPTION_API_KEY=sk-proj-...
TRANSCRIPTION_BASE_URL=https://api.openai.com/v1
TRANSCRIPTION_MODEL=whisper-1

# Option 2: Groq
# TRANSCRIPTION_PROVIDER=groq
# TRANSCRIPTION_API_KEY=gsk_...
# TRANSCRIPTION_BASE_URL=https://api.groq.com/openai/v1
# TRANSCRIPTION_MODEL=whisper-large-v3

# Option 3: Custom/vLLM self-hosted
# TRANSCRIPTION_PROVIDER=custom
# TRANSCRIPTION_API_KEY=<optional>
# TRANSCRIPTION_BASE_URL=http://localhost:8000/v1
# TRANSCRIPTION_MODEL=whisper-large-v3-turbo

# Summary Configuration
# OpenAI-compatible /chat/completions endpoint (openai/groq/openrouter/ollama/custom)
SUMMARY_PROVIDER=openai
SUMMARY_API_KEY=sk-proj-...
SUMMARY_BASE_URL=https://api.openai.com/v1
SUMMARY_MODEL=gpt-4o-mini
SUMMARY_TEMPERATURE=0.3
SUMMARY_MAX_TOKENS=1024
SUMMARY_LANGUAGE=en

# Diarization Server Configuration
# Used by crates/diarize (bin: diarize-server)
DIARIZE_HOST=0.0.0.0
DIARIZE_PORT=8002
# Path to pyannote segmentation ONNX model (required)
# Download: https://github.com/k2-fsa/sherpa-onnx/releases/download/speaker-segmentation-models/sherpa-onnx-pyannote-segmentation-3-0.tar.bz2
DIARIZE_SEGMENTATION_MODEL=$HOME/.meeting-agent/models/sherpa-onnx-pyannote-segmentation-3-0/model.onnx
# Path to 3D-Speaker ERes2Net embedding ONNX model (required)
# Download: https://github.com/k2-fsa/sherpa-onnx/releases/download/speaker-recongition-models/3dspeaker_speech_eres2net_base_sv_zh-cn_3dspeaker_16k.onnx
DIARIZE_EMBEDDING_MODEL=$HOME/.meeting-agent/models/3dspeaker_speech_eres2net_base_sv_zh-cn_3dspeaker_16k.onnx
# Optional: force number of speakers (0 = auto-detect)
DIARIZE_NUM_SPEAKERS=0
# Optional: clustering threshold for speaker grouping (0.0-1.0)
DIARIZE_CLUSTERING_THRESHOLD=0.5
# Optional: max request body size in MB accepted by diarize-server (default 512)
DIARIZE_MAX_BODY_MB=512

# Diarization Client Configuration
# Used by the import pipeline (crates/core) when calling diarize-server
# Optional: diarize client request timeout in seconds (default 900)
DIARIZE_TIMEOUT_SECS=900

# Logging
RUST_LOG=info
