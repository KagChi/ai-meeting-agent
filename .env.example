# Meeting Agent Environment Variables

# Server Configuration
MEETING_AGENT_PORT=8080
MEETING_AGENT_HOST=127.0.0.1
MEETING_AGENT_DATA_DIR=~/.meeting-agent
MEETING_AGENT_API_KEY=

# Transcription Configuration
# Choose one provider configuration below and uncomment it

# Option 1: OpenAI
TRANSCRIPTION_PROVIDER=openai
TRANSCRIPTION_API_KEY=sk-proj-...
TRANSCRIPTION_BASE_URL=https://api.openai.com/v1
TRANSCRIPTION_MODEL=whisper-1
# Optional: chunk long audio into N-second segments (default 600)
TRANSCRIPTION_CHUNK_SECONDS=600
# Optional: parallel chunk transcription requests (default 2)
TRANSCRIPTION_CHUNK_CONCURRENCY=2

# Option 2: Groq
# TRANSCRIPTION_PROVIDER=groq
# TRANSCRIPTION_API_KEY=gsk_...
# TRANSCRIPTION_BASE_URL=https://api.groq.com/openai/v1
# TRANSCRIPTION_MODEL=whisper-large-v3

# Option 3: Custom/vLLM self-hosted
# TRANSCRIPTION_PROVIDER=custom
# TRANSCRIPTION_API_KEY=<optional>
# TRANSCRIPTION_BASE_URL=http://localhost:8000/v1
# TRANSCRIPTION_MODEL=whisper-large-v3-turbo

# Summary Configuration
# OpenAI-compatible /chat/completions endpoint (openai/groq/openrouter/ollama/custom)
SUMMARY_PROVIDER=openai
SUMMARY_API_KEY=sk-proj-...
SUMMARY_BASE_URL=https://api.openai.com/v1
SUMMARY_MODEL=gpt-4o-mini
SUMMARY_TEMPERATURE=0.3
SUMMARY_MAX_TOKENS=1024
SUMMARY_LANGUAGE=en

# Diarization Configuration (in-process, speakrs)
# Enable speaker diarization during import (default false)
DIARIZE_ENABLED=false
# speakrs execution backend: cpu|coreml|coreml-fast|cuda|cuda-fast|migraphx
# cpu = portable (default); coreml = macOS CoreML; cuda = NVIDIA GPU
DIARIZE_EXECUTION_MODE=cpu
# Optional: local model directory (blank = download from huggingface.co/avencera/speakrs-models on first use)
DIARIZE_MODEL_DIR=

# Logging
RUST_LOG=info
