# Copy to .env for local `bun run dev` (Docker Compose injects env instead).
# DO NOT use 127.0.0.1 for MEETING_AGENT_URL inside Docker — use the API service name.

BOT_PORT=8091
BOT_HOST=0.0.0.0
BOT_API_KEY=
BOT_NAME=BMW-Lab-Bot

DATA_DIR=./data
# SQLITE_PATH=./data/meeting-bot.db

# Agent import target (from bot container / host)
MEETING_AGENT_URL=http://127.0.0.1:8080
MEETING_AGENT_API_KEY=

HEADLESS=false
JOIN_TIMEOUT_MS=900000
ALONE_TIMEOUT_MS=300000
MAX_CONCURRENT_BOTS=1
KEEP_RECORDING=true
