{
  "info": {
    "name": "ai-meeting-agent",
    "_postman_id": "a1b2c3d4-0001-4000-8000-000000000001",
    "description": "Meeting Agent REST API — transcription, summarization, and management.\n\nBase URL default: http://127.0.0.1:8080\n\nAuth: If server.api_key is configured, all endpoints except /health, /version, /docs, /api-docs/openapi.json require an `Authorization` or `X-API-Key` header matching the key (raw value, no Bearer prefix).\n\nGenerated from source at crates/server/src/.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://127.0.0.1:8080",
      "description": "Server base URL (host:port from config)"
    },
    {
      "key": "api_key",
      "value": "",
      "description": "API key for auth. Leave empty if server runs in open-access mode. When set, sent as both Authorization and X-API-Key headers."
    },
    {
      "key": "meeting_id",
      "value": "00000000-0000-0000-0000-000000000000",
      "description": "Meeting UUID — set after creating a meeting or importing audio"
    },
    {
      "key": "template",
      "value": "key_points",
      "description": "Summary template: key_points | action_items | decisions | full"
    },
    {
      "key": "job_id",
      "value": "",
      "description": "Job ID — set after POST /import or POST /meetings/:id/summary"
    }
  ],
  "auth": {
    "type": "apikey",
    "apikey": [
      { "key": "key", "value": "Authorization", "type": "string" },
      { "key": "value", "value": "{{api_key}}", "type": "string" },
      { "key": "in", "value": "header", "type": "string" }
    ]
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// If api_key is empty, remove auth header so public endpoints work cleanly",
          "if (pm.collectionVariables.get('api_key') === '') {",
          "  pm.request.headers.remove('Authorization');",
          "  pm.request.headers.remove('X-API-Key');",
          "} else {",
          "  pm.request.headers.add({key: 'X-API-Key', value: pm.collectionVariables.get('api_key')});",
          "}"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "System",
      "description": "Health and version endpoints — public, no auth required.",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/health",
              "host": ["{{base_url}}"],
              "path": ["health"]
            },
            "description": "Returns server health status. Always public — no auth required even when API key is configured."
          },
          "response": [
            {
              "name": "200 OK",
              "originalRequest": { "method": "GET", "url": "{{base_url}}/health" },
              "status": "OK",
              "code": 200,
              "body": "{\n  \"status\": \"ok\"\n}"
            }
          ]
        },
        {
          "name": "Version Info",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/version",
              "host": ["{{base_url}}"],
              "path": ["version"]
            },
            "description": "Returns server version and name. Always public — no auth required."
          },
          "response": [
            {
              "name": "200 OK",
              "originalRequest": { "method": "GET", "url": "{{base_url}}/version" },
              "status": "OK",
              "code": 200,
              "body": "{\n  \"version\": \"0.1.0\",\n  \"name\": \"meeting-agent-server\"\n}"
            }
          ]
        }
      ]
    },
    {
