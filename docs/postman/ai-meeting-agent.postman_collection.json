          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 201', () => pm.response.to.have.status(201));",
                  "var json = pm.response.json();",
                  "if (json.id) { pm.collectionVariables.set('meeting_id', json.id); }"
                ]
              }
            }
          ],
          "response": [
            {
              "name": "201 Created",
              "originalRequest": { "method": "POST", "url": "{{base_url}}/meetings" },
